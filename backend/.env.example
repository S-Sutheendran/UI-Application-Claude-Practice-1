# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite — default, no setup required)
DATABASE_URL=sqlite+aiosqlite:///./focusmind.db

# Production (PostgreSQL — uncomment and set)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/focusmind

# ── Google Drive Backup ──────────────────────────────────────────────────────
# Path to your service-account credentials JSON file
GOOGLE_CREDENTIALS_JSON=./credentials/google_service_account.json

# Google Drive folder ID where backups will be stored
# Create a folder in Drive and paste the ID from the URL
BACKUP_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Max backups to keep per user in Drive before oldest is deleted
MAX_BACKUPS_PER_USER=10

# ── Productivity Score Weights (must sum to 1.0) ──────────────────────────────
SCORE_WEIGHT_FOCUS=0.40
SCORE_WEIGHT_POMODOROS=0.30
SCORE_WEIGHT_TASKS=0.20
SCORE_WEIGHT_STREAK=0.10

# ── Score Denominators (what counts as 100% for each metric) ─────────────────
SCORE_MAX_FOCUS_MINUTES=120
SCORE_MAX_POMODOROS=8
SCORE_MAX_TASKS=5
SCORE_MAX_STREAK_DAYS=7

# ── Admin OTP (SMS via Twilio) ───────────────────────────────────────────────
# Leave TWILIO_ACCOUNT_SID empty to use console fallback in development
# (OTP will be printed to the terminal instead of sent by SMS)
#
# To enable real SMS:
#   1. Create a free Twilio account at https://www.twilio.com
#   2. Get a phone number (trial numbers work fine)
#   3. Fill in the three values below
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15005550006   # your Twilio phone number in E.164 format

# OTP expiry and max failed attempts before invalidation
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:3001","exp://localhost:8081"]
